---
const {
    prefix = "md",
    fileTitle = "document.md",
    editorHeightClass = "h-96",
    editorPlaceholder = "支持 Markdown",
} = Astro.props;
---

<div class="md-ide-shell glass-panel" data-md-prefix={prefix}>
    <div class="md-ide-topbar">
        <span class="md-ide-dot md-ide-dot-red"></span>
        <span class="md-ide-dot md-ide-dot-yellow"></span>
        <span class="md-ide-dot md-ide-dot-green"></span>
        <span class="md-ide-title">{fileTitle}</span>
    </div>

    <div id={`${prefix}-toolbar`} class="md-ide-toolbar">
        <div id={`${prefix}-toolbar-left`} class="md-ide-toolbar-left">
            <div class="md-tool-group" data-group="structure">
                <button type="button" class="md-group-toggle" data-group-toggle title="结构">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M4 6h16M4 12h10M4 18h16"></path>
                    </svg>
                </button>
                <div class="md-group-body">
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="# |"
                        title="一级标题"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M7 4v16M13 4v16M4 9h12M3 15h12"></path>
                        </svg>
                        <span class="md-sr-only">一级标题</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="## |"
                        title="二级标题"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M6 4v16M11 4v16M3 9h11M2 15h12M16 8c0-1.7 1.3-3 3-3s3 1.3 3 3c0 3-5.5 4-5.5 7h5.5"></path>
                        </svg>
                        <span class="md-sr-only">二级标题</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="### |"
                        title="三级标题"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M6 4v16M11 4v16M3 9h11M2 15h12M18 7h2a2 2 0 1 1 0 4h-2h2a2 2 0 1 1 0 4h-2"></path>
                        </svg>
                        <span class="md-sr-only">三级标题</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="> |"
                        title="引用"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M8 7H4v6h4v4l4-5V7H8zm10 0h-4v6h4v4l4-5V7h-4z"></path>
                        </svg>
                        <span class="md-sr-only">引用</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="- |"
                        title="无序列表"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M8 6h13M8 12h13M8 18h13"></path>
                            <circle cx="4" cy="6" r="1.5"></circle>
                            <circle cx="4" cy="12" r="1.5"></circle>
                            <circle cx="4" cy="18" r="1.5"></circle>
                        </svg>
                        <span class="md-sr-only">无序列表</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="1. |"
                        title="有序列表"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M9 6h12M9 12h12M9 18h12M4 5v3M3 8h2M3 14h3a1.5 1.5 0 0 1 0 3H3l3 0"></path>
                        </svg>
                        <span class="md-sr-only">有序列表</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="- [ ] |"
                        title="任务列表"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <rect x="3" y="4" width="5" height="5" rx="1"></rect>
                            <rect x="3" y="15" width="5" height="5" rx="1"></rect>
                            <path d="M11 7h10M11 18h10"></path>
                        </svg>
                        <span class="md-sr-only">任务列表</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="\n---\n"
                        title="分割线"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3 12h18"></path>
                            <circle cx="7" cy="12" r="1.2"></circle>
                            <circle cx="12" cy="12" r="1.2"></circle>
                            <circle cx="17" cy="12" r="1.2"></circle>
                        </svg>
                        <span class="md-sr-only">分割线</span>
                    </button>
                </div>
            </div>

            <div class="md-tool-group" data-group="format">
                <button type="button" class="md-group-toggle" data-group-toggle title="样式">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M5 5h14M8 5l2 14h4l2-14"></path>
                    </svg>
                </button>
                <div class="md-group-body">
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="**{sel}|**"
                        title="加粗"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M7 5h7a4 4 0 1 1 0 8H7zm0 8h8a4 4 0 1 1 0 8H7z"></path>
                        </svg>
                        <span class="md-sr-only">加粗</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="*{sel}|*"
                        title="斜体"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M15 4h5M4 20h5M14 4L10 20"></path>
                        </svg>
                        <span class="md-sr-only">斜体</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="~~{sel}|~~"
                        title="删除线"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M4 12h16M7 7a4 4 0 0 1 4-3c2.2 0 4 1.3 4 3M7 17a4 4 0 0 0 4 3c2.2 0 4-1.3 4-3"></path>
                        </svg>
                        <span class="md-sr-only">删除线</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="`{sel}|`"
                        title="行内代码"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="m9 7-5 5 5 5M15 7l5 5-5 5"></path>
                        </svg>
                        <span class="md-sr-only">行内代码</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="[{sel}](|)"
                        title="链接"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M10 14a4 4 0 0 1 0-6l2-2a4 4 0 1 1 6 6l-1.5 1.5M14 10a4 4 0 0 1 0 6l-2 2a4 4 0 1 1-6-6L7.5 10.5"></path>
                        </svg>
                        <span class="md-sr-only">链接</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="![alt](|)"
                        title="图片"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                            <circle cx="9" cy="10" r="1.5"></circle>
                            <path d="m21 16-5-4-4 3-2-2-7 6"></path>
                        </svg>
                        <span class="md-sr-only">图片</span>
                    </button>
                </div>
            </div>

            <div class="md-tool-group" data-group="blocks">
                <button type="button" class="md-group-toggle" data-group-toggle title="块级">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <rect x="3" y="4" width="18" height="16" rx="2"></rect>
                        <path d="M7 8h10M7 12h6M7 16h10"></path>
                    </svg>
                </button>
                <div class="md-group-body">
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="```cpp\n|\n```"
                        title="代码块"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="m9 8-4 4 4 4M15 8l4 4-4 4M13 6l-2 12"></path>
                        </svg>
                        <span class="md-sr-only">代码块</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="```cpp line-numbers lines=2\n|\n```"
                        title="代码高亮行"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="m9 8-4 4 4 4M15 8l4 4-4 4M13 6l-2 12M3 4v16"></path>
                        </svg>
                        <span class="md-sr-only">代码高亮行</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="| A | B |\n| - | - |\n| ^ | < |\n"
                        title="表格"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                            <path d="M3 10h18M3 14h18M9 5v14M15 5v14"></path>
                        </svg>
                        <span class="md-sr-only">表格</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="::cute-table{tuack}\n| A | B |\n| - | - |\n| 1 | 2 |\n"
                        title="可爱表格"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <rect x="3" y="5" width="18" height="14" rx="4"></rect>
                            <path d="M7 10h10M7 14h6"></path>
                        </svg>
                        <span class="md-sr-only">可爱表格</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet=":::align{center}\n|\n:::\n"
                        title="居中块"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M5 6h14M7 10h10M6 14h12M8 18h8"></path>
                        </svg>
                        <span class="md-sr-only">居中块</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet=":::align{right}\n|\n:::\n"
                        title="右对齐块"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M5 6h14M9 10h10M7 14h12M11 18h8"></path>
                        </svg>
                        <span class="md-sr-only">右对齐块</span>
                    </button>
                </div>
            </div>

            <div class="md-tool-group" data-group="panel">
                <button type="button" class="md-group-toggle" data-group-toggle title="提示块">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 3 2.8 20h18.4L12 3zm0 6v5m0 3h.01"></path>
                    </svg>
                </button>
                <div class="md-group-body">
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet=":::info[提示]{open}\n|\n:::\n"
                        title="信息块"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="12" cy="12" r="9"></circle>
                            <path d="M12 10v6M12 7h.01"></path>
                        </svg>
                        <span class="md-sr-only">信息块</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet=":::success[成功]{open}\n|\n:::\n"
                        title="成功块"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="12" cy="12" r="9"></circle>
                            <path d="m8 12 2.5 2.5L16 9"></path>
                        </svg>
                        <span class="md-sr-only">成功块</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet=":::warning[警告]{open}\n|\n:::\n"
                        title="警告块"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 3 2.8 20h18.4L12 3zm0 6v5m0 3h.01"></path>
                        </svg>
                        <span class="md-sr-only">警告块</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet=":::error[错误]{open}\n|\n:::\n"
                        title="错误块"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="12" cy="12" r="9"></circle>
                            <path d="m9 9 6 6m0-6-6 6"></path>
                        </svg>
                        <span class="md-sr-only">错误块</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet=":::epigraph[作者]\n|\n:::\n"
                        title="题记"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M8 7H4v6h4v4l4-5V7H8zm10 0h-4v6h4v4l4-5V7h-4z"></path>
                        </svg>
                        <span class="md-sr-only">题记</span>
                    </button>
                    <button
                        type="button"
                        class="md-tool-btn md-icon-btn"
                        data-snippet="::hidden[|]"
                        title="隐藏叶子"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3 12s3.5-5 9-5 9 5 9 5-3.5 5-9 5-9-5-9-5z"></path>
                            <path d="M8 8l8 8"></path>
                        </svg>
                        <span class="md-sr-only">隐藏叶子</span>
                    </button>
                </div>
            </div>
        </div>
        <div class="md-ide-toolbar-right">
            <button
                type="button"
                class="md-tool-btn md-view-btn"
                data-action="copy-markdown"
                title="复制 Markdown"
            >
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <rect x="9" y="7" width="11" height="13" rx="2"></rect>
                    <path d="M6 16H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                <span class="md-sr-only">复制 Markdown</span>
            </button>
            <button type="button" class="md-tool-btn md-view-btn" data-view="editor" title="仅编辑">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <rect x="4" y="4" width="16" height="16" rx="2"></rect>
                    <path d="M8 8h8M8 12h6M8 16h8"></path>
                </svg>
                <span class="md-sr-only">仅编辑</span>
            </button>
            <button type="button" class="md-tool-btn md-view-btn" data-view="split" title="分屏">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <rect x="3" y="4" width="18" height="16" rx="2"></rect>
                    <path d="M12 4v16"></path>
                </svg>
                <span class="md-sr-only">分屏</span>
            </button>
            <button type="button" class="md-tool-btn md-view-btn" data-view="preview" title="仅预览">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M3 12s3.5-6 9-6 9 6 9 6-3.5 6-9 6-9-6-9-6z"></path>
                    <circle cx="12" cy="12" r="2.6"></circle>
                </svg>
                <span class="md-sr-only">仅预览</span>
            </button>
        </div>
    </div>

    <div id={`${prefix}-split`} class={`md-ide-split ${editorHeightClass}`}>
        <div id={`${prefix}-pane-editor`} class="md-ide-pane md-ide-pane-editor">
            <div id={`${prefix}-ide`} class="md-ide-editor"></div>
            <textarea
                id={`${prefix}-input`}
                class="glass-input hidden md-ide-fallback"
                placeholder={editorPlaceholder}
            ></textarea>
        </div>
        <div id={`${prefix}-divider`} class="md-ide-divider" role="separator"></div>
        <div id={`${prefix}-pane-preview`} class="md-ide-pane md-ide-pane-preview">
            <div id={`${prefix}-preview`} class="md-ide-preview leading-relaxed"></div>
        </div>
    </div>

    <div id={`${prefix}-ide-status`} class="md-ide-status">行 1, 列 1</div>
</div>
