---
const {
    svg,
    href = "#",
    label = "",
    required = false,
    active = false,
} = Astro.props;
---

<div class="mt-4">
    <a
        href={href}
        class={`relative flex items-center h-10 rounded-xl px-2 transition-colors duration-150 ${
            active ? "bg-white/16 text-[var(--text-color)]" : "text-[var(--text-color)]/82 hover:text-[var(--text-color)]"
        }`}
        aria-label={label}
        title={label}
        aria-current={active ? "page" : undefined}
    >
        <span class="flex items-center justify-center w-6" aria-hidden="true">
            <slot name="icon">{svg}</slot>
        </span>

        <span
            class="absolute left-10 top-1/2 -translate-y-1/2
		                    whitespace-nowrap
		                 	opacity-0
	                		group-hover:opacity-100
	                		transition-opacity duration-150 pointer-events-none"
            aria-hidden="true"
        >
            {label}
        </span>
    </a>
</div>
