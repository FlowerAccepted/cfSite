---
import BaseLayout from "../layouts/BaseLayout.astro";
// @ts-ignore
import ErrorMarkSign from "@/components/signs/ErrorMarkSign.astro";
import CorrectMarkSign from "@/components/signs/CorrectMarkSign.astro";
import MarkdownIDE from "@/components/MarkdownIDE.astro";
import TopToast from "@/components/TopToast.astro";
const API_BASE = import.meta.env.PUBLIC_API_BASE;
---

<BaseLayout title="用户中心 - FAc's Site" mainClass="whoami-main">
    <section id="profile-card" class="glass-panel hidden">
        <div class="flex items-center gap-4">
            <img id="avatar" class="h-20 w-20 rounded-full" alt="用户头像" />
            <div>
                <h2 id="nickname" class="text-xl font-bold"></h2>
                <p id="username" class="text-sm opacity-70"></p>
            </div>
        </div>

        <div class="mt-4">
            <p id="bio-display" class="mt-1 cursor-pointer"></p>
            <div id="bio-editor" class="mt-2 hidden items-center gap-2">
                <input
                    id="bio-input"
                    class="glass-input"
                    style="width: 100%;"
                    placeholder="输入个签"
                />
                <button class="glass-btn" id="bio-cancel">取消</button>
                <button class="glass-btn" id="bio-save">确定</button>
            </div>
        </div>

        <button class="glass-btn mt-4" id="intro-edit-btn">编辑个人简介</button>

        <h1 id="intro-label" class="mt-4">个人简介</h1>
        <section id="intro-view" class="mt-2">
            <div id="intro-render" class="leading-relaxed"></div>
        </section>

        <section id="intro-editor" class="mt-4 hidden">
            <p class="text-sm opacity-70">编辑个人简介</p>
            <div class="mt-2">
                <MarkdownIDE prefix="intro" fileTitle="intro.md" editorHeightClass="h-[28rem]" />
            </div>
            <div class="mt-3 flex items-center justify-end gap-2">
                <button class="glass-btn" id="intro-apply">保存</button>
                <button class="glass-btn" id="intro-cancel">取消</button>
                <button class="glass-btn" id="intro-save">确定</button>
            </div>
        </section>
    </section>

    <div
        id="un-auth"
        class="fixed inset-0 z-[2000] hidden items-center justify-center bg-black/50"
    >
        <div
            class="glass-panel h-2/5 w-2/5 flex flex-col items-center justify-center gap-10 text-center"
        >
            <ErrorMarkSign size={128} />
            <h1>请先登录</h1>
            <button class="glass-btn justify-center" id="go-login">去登录</button>
        </div>
    </div>

    <TopToast id="intro-save-toast" text="保存成功">
        <CorrectMarkSign slot="icon" size={36} />
    </TopToast>

    <script define:vars={{ API_BASE }}>
        window.__WHOAMI_API_BASE__ = API_BASE;
    </script>

    <script is:inline>
        window.__showWhoamiUnauth = () => {
            const profile = document.getElementById("profile-card");
            const unauth = document.getElementById("un-auth");
            profile?.classList.add("hidden");
            unauth?.classList.remove("hidden");
            unauth?.classList.add("flex");
        };
    </script>

    <script type="module">
        import("/scripts/whoami.js")
            .then(({ initWhoami }) => initWhoami())
            .catch((err) => {
                console.error("whoami module load failed:", err);
                window.__showWhoamiUnauth?.();
            });
    </script>
</BaseLayout>
